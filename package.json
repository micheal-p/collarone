{
  "name": "collarone",
  "version": "1.0.0",
  "private": true,
  "description": "Collarone — the business platform for Nigerian companies (HR, payroll, CRM, finance and more, all under one login)",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "seed": "npm run seed --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "pg": "^8.22.0"
  }
}
