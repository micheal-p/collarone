# Copy to .env — values from your Supabase project's Settings → API page.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set to true to run the UI against a local mock (no Supabase project needed) —
# useful for exploring the frontend without setting up a backend first.
VITE_DEMO_MODE=false
